+  removeTopMultipartMixedLayer(mimeText) {
+    // Split into top-level headers and rest of message.
+    const headerBoundaryPosition = mimeText.search(/\n\r?\n/);
+    let bodyText = mimeText.slice(headerBoundaryPosition);
+    if (bodyText.search(/^content-type:\s*multipart\/signed/im) < 0) {
+      // Nothing to do.
+      return mimeText;
+    }
+
+    const headerText = mimeText.slice(0, headerBoundaryPosition);
+
+    // Find top-level Content-Type: multipart/mixed header and boundary.
+    // The regex matched the content-type header and all folded continuation lines.
+    // ?: is a non-capturing group.
+    const ctRegex =
+      /\r?\ncontent-type:\s*multipart\/mixed\s*;\s*boundary="([^"]+)"[^\n\r]*(?:\r?\n[ \t].*)*/im;
+
+    const match = headerText.match(ctRegex);
+    if (!match) {
+      // Nothing to do.
+      return mimeText;
+    }
+
+    const boundary = match[1];
+
+    // Remove the Content-Type header from top-level headers.
+    const newHeaderText = headerText.replace(ctRegex, "");
+
+    // Boundary markers.
+    const firstBoundaryRegex = new RegExp(
+      "\\r?\\n--" + this.escapeRegex(boundary) + "[ \\t]*\\r?\\n(?:\\r?\\n)*",
+      "m"
+    );
+
+    const closingBoundaryRegex = new RegExp(
+      "\\r?\\n--" + this.escapeRegex(boundary) + "--[ \\t]*(?:\\r?\\n)*$",
+      "m"
+    );
+
+    // Remove first opening boundary + following empty lines.
+    bodyText = bodyText.replace(firstBoundaryRegex, "");
+
+    // Remove final closing boundary.
+    bodyText = bodyText.replace(closingBoundaryRegex, "");
+
+    return newHeaderText + bodyText;
+  }
+
+  escapeRegex(str) {
+    return str.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
+  }
+
