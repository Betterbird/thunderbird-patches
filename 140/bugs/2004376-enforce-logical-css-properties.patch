@@ -122,24 +122,24 @@ mailattachcount {
 /* ::::: images ::::: */
 
 img {
   &[shrinktofit] {
-    max-width: 100% !important;
+    max-inline-size: 100% !important;
 
     &[overflowing] {
       cursor: zoom-in;
       /* If we detect we're shrinking the image, force it to keep its aspect
