+var checkerReadyObserver = {
+  _topic: "inlineSpellChecker-spellCheck-ended",
+  _isReady: false,
+
+  observe(aSubject, aTopic) {
+    if (aSubject != this._subject || aTopic != this._topic) {
+      return;
+    }
+    this._isReady = true;
+  },
+
+  _isAdded: false,
+
+  addObserver(subject) {
+    if (this._isAdded) {
+      return;
+    }
+
+    Services.obs.addObserver(this, this._topic);
+    this._isAdded = true;
+    this._subject = subject;
+  },
+
+  removeObserver() {
+    if (!this._isAdded) {
+      return;
+    }
+
+    Services.obs.removeObserver(this, this._topic);
+    this._isAdded = false;
+    this._isReady = false;
+  },
+
+  isReady() {
+    return this._isReady;
+  },
+};
