diff --git a/mailnews/compose/src/nsMsgCompose.cpp b/mailnews/compose/src/nsMsgCompose.cpp
--- a/mailnews/compose/src/nsMsgCompose.cpp
+++ b/mailnews/compose/src/nsMsgCompose.cpp
@@ -524,8 +524,19 @@ nsMsgCompose::ConvertAndLoadComposeWindo
           }
         }
       }
 
+      // Insert a <br> before the cite prefix.
+      // Note that a signature wrapped into a <pre> doesn't need this as the
+      // <pre> has a `margin-block: 1em`, so there is space
+      // between the signature and a following <div class="moz-cite-prefix">.
+      // It's also not needed for forwarding, since the forward container
+      // has plenty of leading space.
+      if (aHTMLEditor && sigOnTop && StringBeginsWith(aSignature, u"<div"_ns)) {
+        // htmlEditor->InsertLineBreak(); inserts a <br> wrapped into a <p> or <div>.
+        htmlEditor->InsertHTML(u"<br>"_ns);
+      }
+
       InsertDivWrappedTextAtSelection(aPrefix, u"moz-cite-prefix"_ns);
     }
 
