   try {
     const checker = editor.getInlineSpellChecker(true);
-    checker.enableRealTimeSpell = Services.prefs.getBoolPref("mail.spellcheck.inline", true);
+    let prefValue = Services.prefs.getCharPref("spellchecker.dictionary");
+    // Get rid of empty entries caused by trailing commas in pref value.
+    const dictionaries = Array.from(new Set(prefValue?.split(","))).filter(Boolean);
+    if (dictionaries.length) {
+      checker.enableRealTimeSpell = Services.prefs.getBoolPref("mail.spellcheck.inline", true);
+      // The deal is this:
+      // When the spell check is enabled, it will only take new dictionaries
+      // when the initial spellcheck is complete. The sophisticated solution can be seen in:
+      // https://github.com/Betterbird/thunderbird-patches/blob/main/140/bugs/NNN11-fix-multiple-dicts.patch
+      // Here we will just hope and pray that things will work with a timeout.
+      setTimeout(async () => {
+        try {
+          await checker.spellChecker.setCurrentDictionaries(dictionaries);
+          prefValue = dictionaries.join(",");
+          console.info("Set calendar spellcheck dictionaries", prefValue);
+          // After we set the dictionaries, we need to recheck.
+          checker.spellCheckRange(null);
+
+          // Unfortunately, `setCurrentDictionaries()` triggers this code:
+          // https://searchfox.org/firefox-main/rev/4524afcc186654ad357e48fec686249515860ac8/editor/spellchecker/EditorSpellCheck.cpp#620-621
+          // https://searchfox.org/firefox-main/rev/4524afcc186654ad357e48fec686249515860ac8/editor/spellchecker/EditorSpellCheck.cpp#103
+          // which appends a trailing comma. This greatly upsets the code in MsgComposeCommands.js.
+          // So fix the pref here.
+          Services.prefs.setCharPref("spellchecker.dictionary", prefValue);
+        } catch (ex) {
+          console.error("Cannot set calendar spellcheck dictionaries", ex);
+        }
+      }, 1500);
+    }
   } catch (ex) {
-    // No dictionaries.
+    // Let's see what's wrong here.
+    console.error(ex);
   }
 
