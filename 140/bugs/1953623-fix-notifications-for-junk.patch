# Parent  24c6a705a9a4ad6428e273b2e5cfe8bf8f59884a
Bug 1953623 - Don't check folder lock before running junk filters (when not pop) so that notifications don't show junk. r=tobyp

Prior to https://hg-edge.mozilla.org/comm-central/rev/9ba85c3b7905 non-pop3 wasn't checking locking so I we should be ok not to.
With this patch, we'd only check the lock for pop, like before.

Differential Revision: https://phabricator.services.mozilla.com/D296322

diff --git a/mailnews/base/src/nsMsgDBFolder.cpp b/mailnews/base/src/nsMsgDBFolder.cpp
--- a/mailnews/base/src/nsMsgDBFolder.cpp
+++ b/mailnews/base/src/nsMsgDBFolder.cpp
@@ -2163,20 +2163,8 @@ nsMsgDBFolder::CallFilterPlugins(nsIMsgW
 
   nsCString folderName;
   GetPrettyName(folderName);
 
-  bool isLocked;
-  GetLocked(&isLocked);
-  if (isLocked) {
-    MOZ_LOG(
-        FILTERLOGMODULE, LogLevel::Info,
-        ("Won't run filter plugins on locked folder '%s'", folderName.get()));
-    return NS_ERROR_FAILURE;
-  }
-
-  MOZ_LOG(FILTERLOGMODULE, LogLevel::Info,
-          ("Running filter plugins on folder '%s'", folderName.get()));
-
   nsCOMPtr<nsIMsgIncomingServer> server;
   nsCOMPtr<nsISpamSettings> spamSettings;
   int32_t spamLevel = 0;
 
@@ -2196,8 +2184,24 @@ nsMsgDBFolder::CallFilterPlugins(nsIMsgW
   nsCOMPtr<nsIJunkMailPlugin> junkMailPlugin = do_QueryInterface(filterPlugin);
   if (!junkMailPlugin)  // we currently only support the junk mail plugin
     return NS_OK;
 
+  if (serverType.EqualsLiteral("pop3") || serverType.EqualsLiteral("none")) {
+    // For pop, ensure the folder is locked so e.g. folder compact during
+    // delivery would be safe.
+    bool isLocked;
+    GetLocked(&isLocked);
+    if (isLocked) {
+      MOZ_LOG(
+          FILTERLOGMODULE, LogLevel::Info,
+          ("Won't run filter plugins on locked folder '%s'", folderName.get()));
+      return NS_ERROR_FAILURE;
+    }
+  }
+
+  MOZ_LOG(FILTERLOGMODULE, LogLevel::Info,
+          ("Running filter plugins on folder '%s'", folderName.get()));
+
   // if it's a news folder, then we really don't support junk in the ui
   // yet the legacy spamLevel seems to think we should analyze it.
   // Maybe we should upgrade that, but for now let's not analyze. We'll
   // let an extension set an inherited property if they really want us to
