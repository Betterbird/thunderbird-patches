diff --git a/mail/modules/AccountColorUtils.sys.mjs b/mail/modules/AccountColorUtils.sys.mjs
--- a/mail/modules/AccountColorUtils.sys.mjs
+++ b/mail/modules/AccountColorUtils.sys.mjs
@@ -80,17 +80,20 @@ export const AccountColorUtils = {
         continue;
       }
 
       const serverProperty = `--server-${CSS.escape(server.key)}-color`;
+      const serverProperty2 = `--server-${CSS.escape(server.key)}-display`;
       const color = lazy.FolderTreeProperties.getColor(server.rootFolder.URI);
       // Try to clear the property if no color is available in order to account
       // for custom colors that have been reset to default.
       if (!color) {
         style.removeProperty(serverProperty);
+        style.setProperty(serverProperty2, "none");
         continue;
       }
 
       style.setProperty(serverProperty, color);
+      style.setProperty(serverProperty2, "inline-flex");
     }
   },
 
   /**
