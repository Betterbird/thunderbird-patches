diff --git a/mailnews/base/src/MailNotificationManager.sys.mjs b/mailnews/base/src/MailNotificationManager.sys.mjs
--- a/mailnews/base/src/MailNotificationManager.sys.mjs
+++ b/mailnews/base/src/MailNotificationManager.sys.mjs
@@ -584,15 +584,89 @@ export const MailNotificationManager = n
     // inherits the correct DPI scaling from the start.  The alert queries the
     // primary screen directly via nsIScreenManager to position itself.
     const features = "chrome,dialog,titlebar=no,alert=yes,left=0,top=0";
 
-    Services.ww.openWindow(
+    const win = Services.ww.openWindow(
       null,
       "chrome://messenger/content/newmailalert.xhtml",
       "_blank",
       features,
       args
     );
+
+    if (
+      Services.prefs.getBoolPref("mail.notification.show_on_app_screen", false)
+    ) {
+      const appWindow = Services.wm.getMostRecentWindow("mail:3pane");
+      if (appWindow) {
+        const winScreen = win.screen;
+        const appLeft = appWindow.screenLeft * appWindow.devicePixelRatio;
+        const appTop = appWindow.screenTop * appWindow.devicePixelRatio;
+        const winRight = winScreen.width * win.devicePixelRatio;
+        const winBottom = winScreen.height * win.devicePixelRatio;
+
+        // Is app on a screen other than the primary?
+        if (
+          // To the right of primary?
+          appWindow.screenLeft < 0 ||
+          // To the left of primary?
+          appLeft > winRight ||
+          // On top of primary?
+          appWindow.screenTop < 0 ||
+          // Or below?
+          appTop > winBottom
+        ) {
+          const targetScreen = appWindow.screen;
+
+          // Hack: Assume minimum standard size of 560 x 80.
+          const scaleX = winScreen.width / targetScreen.width;
+          const scaleY = winScreen.height / targetScreen.height;
+          let x, y;
+
+          // Y position.
+          if (appWindow.screenTop < 0) {
+            // Above primary.
+            y =
+              0 -
+              ((80 + 10) * appWindow.devicePixelRatio) / win.devicePixelRatio;
+          } else if (appTop > winBottom) {
+            // Below primary.
+            y =
+              winScreen.height +
+              targetScreen.availHeight * scaleY -
+              80 -
+              10 * scaleY;
+          } else {
+            y =
+              (targetScreen.availTop + targetScreen.availHeight) * scaleY -
+              80 -
+              10 * scaleY;
+          }
+
+          // X position.
+          if (appWindow.screenLeft < 0) {
+            // Left of primary.
+            x =
+              0 -
+              ((560 + 10) * appWindow.devicePixelRatio) / win.devicePixelRatio;
+          } else if (appLeft > winRight) {
+            // Right of primary.
+            x =
+              winScreen.width +
+              targetScreen.availWidth * scaleX -
+              560 -
+              10 * scaleX;
+          } else {
+            // Same column, use the right edge of the target screen.
+            // This assumes the target screen is left-aligned with the primary.
+            x = targetScreen.availWidth * scaleX - 560 - 10 * scaleX;
+          }
+
+          win.moveTo(x, y);
+        }
+      }
+    }
+
     this._customizedAlertShown = true;
     this._saveNotificationTime(folder, newMsgKeys);
   }
 
