# Parent  85264b64efd6a5750682e851e0774aaa33f52c04
Feature: Add "Open in Folder" button next to link in calendar event/task dialogue if the link points to an associated message (mid: link).

diff --git a/calendar/base/content/dialogs/calendar-dialog-utils.js b/calendar/base/content/dialogs/calendar-dialog-utils.js
--- a/calendar/base/content/dialogs/calendar-dialog-utils.js
+++ b/calendar/base/content/dialogs/calendar-dialog-utils.js
@@ -14,8 +14,9 @@
 
 var { cal } = ChromeUtils.importESModule("resource:///modules/calendar/calUtils.sys.mjs");
 var { openLinkExternally } = ChromeUtils.importESModule("resource:///modules/LinkHelper.sys.mjs");
 var { XPCOMUtils } = ChromeUtils.importESModule("resource://gre/modules/XPCOMUtils.sys.mjs");
+var { MailUtils } = ChromeUtils.importESModule("resource:///modules/MailUtils.sys.mjs");
 
 ChromeUtils.defineESModuleGetters(this, {
   CalAlarm: "resource:///modules/CalAlarm.sys.mjs",
 });
@@ -616,4 +617,29 @@ function openAttachmentFromItemSummary(a
   if (attachments.length && attachments[0].uri && attachments[0].uri.spec != "about:blank") {
     openLinkExternally(attachments[0].uri, { addToHistory: false });
   }
 }
+
+function openMidLinkInFolder(url) {
+  if (!url.startsWith("mid:")) {
+    return;
+  }
+  const msgId = url.slice(4);
+  window?.setCursor("wait");
+  const msgHdr = MailUtils.getMsgHdrForMsgId(msgId);
+  window?.setCursor("auto");
+  if (msgHdr) {
+    MailUtils.displayMessageInFolderTab(msgHdr);
+    return;
+  }
+
+  const bundle = Services.strings.createBundle(
+    "chrome://messenger/locale/messenger.properties"
+  );
+  Services.prompt.alert(
+    window,
+    bundle.GetStringFromName("errorOpenMessageForMessageIdTitle"),
+    bundle.formatStringFromName("errorOpenMessageForMessageIdMessage", [
+      `<${msgId}>`,
+    ])
+  );
+}
