# User Betterbird <betterbird@betterbird.eu>
# Date 1784580603 -7200
# Parent  286ce092b6dfce5b9a8851a97e596a4dce2b2e45
Feature and follow-up to bug 2044250: Fix startup in tray for Linux.

diff --git a/mail/base/content/messenger.js b/mail/base/content/messenger.js
--- a/mail/base/content/messenger.js
+++ b/mail/base/content/messenger.js
@@ -139,9 +139,13 @@ var gMailInit = {
     const firstWindow = !SessionStoreManager.initialized;
     _restoredWindowStatePromise = SessionStoreManager.loadingWindow(window);
 
     // Hide this window on startup (if required).
-    this._startInTray(firstWindow);
+    if (AppConstants.platform == "win") {
+      // We'll do it for Linux later. If we did it here, the windows would be
+      // restored too small and in the wrong location.
+      this._startInTray(firstWindow);
+    }
   },
 
   _startInTrayEnabled() {
     return Services.prefs.getBoolPref("mail.startupMinimized", false)
@@ -158,9 +162,13 @@ var gMailInit = {
       const baseWindow = window.docShell.treeOwner.QueryInterface(
         Ci.nsIBaseWindow
       );
       Cc["@mozilla.org/messenger/osintegration;1"]
-        .getService(Ci.nsIMessengerWindowsIntegration)
+        .getService(
+          AppConstants.platform == "win"
+            ? Ci.nsIMessengerWindowsIntegration
+            : Ci.nsIMessengerUnixIntegration
+        )
         .hideWindow(baseWindow);
     };
 
     if (firstWindow) {
@@ -304,8 +312,15 @@ var gMailInit = {
    */
   _delayedStartup() {
     this._cancelDelayedStartup();
 
+    if (AppConstants.platform == "linux") {
+      // Move window to tray later so it restores to full size.
+      // This is how it was done in the now obsolete
+      // 19-feature-startup-minimized.patch.
+      this._startInTray(true);
+    }
+
     MailOfflineMgr.init();
 
     BondOpenPGP.init();
 
