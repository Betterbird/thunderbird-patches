   if (link) {
     onLink = true;
@@ -2112,9 +2161,14 @@ function msgComposeContextOnShowing(even
       link.getAttribute("a") ||
       link.href ||
       "";
     linkUrl = link.href;
-  }
+    try {
+      lastUriHovered = Services.io.newURI(linkUrl);
+      lastUrlHovered = linkUrl;
+    } catch (ex) {}
+  }
+  document.getElementById("openLinkInBrowser").hidden = !lastUriHovered;
 
