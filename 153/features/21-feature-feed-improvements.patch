+  grid-template-columns: min-content auto;
+  grid-gap: 2px;
+  align-items: center;
+}
+
+#feedDetailGrid * {
+  line-height: 1.3;
+}
+
+#feedDetailGrid > label {
+  justify-self: end;
+  text-wrap: nowrap;
+}
+
+/* #nameValue, #locationValue, #selectFolderValue */
+#feedDetailGrid .input-inline {
+  text-overflow: ellipsis;
+  flex: 1;
+}
+
+#statusBox {
+  height: 3em;
+}
+
+#locationBox,
+#folderBox,
+#statusBox,
+#actionButtonsBox {
+  display: flex;
+  align-items: center;
+  /* No ellipsis without this! */
+  min-width: 0;
+}
+
+#locationValidate,
+#createSubFolderLabel {
+  margin-inline: 4px;
+}
+
+#selectFolder {
+  overflow-x: auto;
+}
+
+#feedOptionsGrid {
+  display: grid;
+  grid-gap: 8px;
+  padding-block: 4px;
+}
+
+#updateBox,
+#summaryBox {
+  display: inline-flex;
+  align-items: center;
+  flex-wrap: wrap;
+  border: none;
+  margin: 0;
+  padding: 0;
+}
+
+input[type="number"] {
+  &.size3 {
+    width: calc(3ch + 55px);
+  }
+}
+
+.icon-info {
+  margin: var(--button-margin);
+  vertical-align: middle;
+  cursor: help;
+}
+
 #autotagPrefix {
   max-inline-size: 15em;
 }
 
-#statusContainerBox {
-  block-size: 2.4em;
+/* UI Density customization - match folderPane. */
+
+:root[uidensity="compact"] {
+  & #folderTree > #folderTreeChildren::-moz-tree-row {
+    min-height: 20px;
+  }
+  & #feedDetailGrid {
+    grid-gap: 0;
+  }
+  & #feedOptionsGrid {
+    grid-gap: 4px;
+  }
 }
+:root[uidensity="touch"] {
+  & #folderTree > #folderTreeChildren::-moz-tree-row {
+    min-height: 33px;
+  }
+  & #feedDetailGrid {
+    grid-gap: 2px;
+  }
+  & #feedOptionsGrid {
+    grid-gap: 10px;
+  }
+}
