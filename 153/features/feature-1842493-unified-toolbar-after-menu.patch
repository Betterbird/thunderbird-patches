     padding: var(--unified-customization-padding);
   }
 }
 
+.customizingUnifiedToolbar[tabsintitlebar] #titlebar > unified-toolbar >
+  #unifiedToolbarContainer > .titlebar-buttonbox-container {
+  visibility: visible;
+}
+
 #customizationHeading {
