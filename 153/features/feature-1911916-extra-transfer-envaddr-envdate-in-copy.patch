+                   mCopyState->m_fileStream.get())
+                   ->mTarget)
+                  .get())
+              ->SetEnvelopeDetails(envAddr, envDate);
+        } else {
+          static_cast<MboxMsgOutputStream*>(mCopyState->m_fileStream.get())
+              ->SetEnvelopeDetails(envAddr, envDate);
+        }
+      }
+    }
   } else {
     mCopyState->m_message = nullptr;
