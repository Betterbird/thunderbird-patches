diff --git a/mailnews/compose/src/MimeMessage.sys.mjs b/mailnews/compose/src/MimeMessage.sys.mjs
--- a/mailnews/compose/src/MimeMessage.sys.mjs
+++ b/mailnews/compose/src/MimeMessage.sys.mjs
@@ -171,8 +171,46 @@ export class MimeMessage {
    * Collect top level headers like From/To/Subject into a Map.
    *
    * @returns {Map<string,*>} headers to value mapping.
    */
+  _headerACE(value) {
+    const parsed = jsmime.headerparser.parseAddressingHeader(value, false);
+    let noChange = true;
+    for (const addr of parsed) {
+      const atPos = addr.email.lastIndexOf("@");
+      if (atPos < 0) {
+        continue;
+      }
+      const domain = addr.email.slice(atPos + 1);
+      let needsReplacement = false;
+      for (let i = 0; i < domain.length; i++) {
+        const ch = domain[i];
+        if (ch < " " || ch > "~") {
+          needsReplacement = true;
+          break;
+        }
+      }
+      if (!needsReplacement) {
+        continue;
+      }
+      noChange = false;
+      const idnService = Cc["@mozilla.org/network/idn-service;1"].getService(
+        Ci.nsIIDNService
+      );
+      addr.email =
+        addr.email.slice(0, atPos + 1) + idnService.convertUTF8toACE(domain);
+    }
+
+    if (noChange) {
+      return value;
+    }
+    return parsed
+      .map(addr =>
+        MailServices.headerParser.makeMimeAddress(addr.name, addr.email)
+      )
+      .join(", ");
+  }
+
