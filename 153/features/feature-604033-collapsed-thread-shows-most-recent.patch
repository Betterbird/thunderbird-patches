   m_flags[index] = flags;
   int32_t numRemoved = -rowDelta;
 
+  if (fixRoot && CollapseToMostRecent()) {
+    // Make the root display the most recent child.
+    nsCOMPtr<nsIMsgThread> pThread;
+    nsresult rv = GetThreadContainingIndex(index, getter_AddRefs(pThread));
+    NS_ENSURE_SUCCESS(rv, rv);
+    uint32_t newestDate = 0;
+    uint32_t numChildren;
+    nsMsgKey newestKey = nsMsgKey_None;
+
+    pThread->GetNumChildren(&numChildren);
+    for (uint32_t childIndex = 0; childIndex < numChildren; childIndex++) {
+      nsCOMPtr<nsIMsgDBHdr> child;
+      rv = pThread->GetChildHdrAt(childIndex, getter_AddRefs(child));
+      if (NS_SUCCEEDED(rv)) {
+        uint32_t msgDate;
+        child->GetDateInSeconds(&msgDate);
+        if (msgDate > newestDate) {
+          newestDate = msgDate;
+          child->GetMessageKey(&newestKey);
+        }
+      }
+    }
+
+    if (newestKey != nsMsgKey_None) {
+      // Find index.
+      uint32_t newestIndex;
+      if (ReversedThreading()) {
+        // Start looking at the last child of the thread which is at the
+        // top in reversed threading. Likely it's already the one we want.
+        newestIndex = index - numRemoved;
+        newestIndex = m_keys.IndexOf(newestKey, newestIndex);
+      } else {
+        // Start looking at the last child of the thread which is at the
+        // bottom in reversed threading. Likely it's already the one we want.
+        newestIndex = index + numRemoved;
+        newestIndex = m_keys.LastIndexOf(newestKey, newestIndex);
+      }
+      // Don't crash if something went wrong.
+      if (!IsValidIndex(newestIndex)) {
+        return NS_ERROR_UNEXPECTED;
+      }
+      m_keys[index] = m_keys[newestIndex];
+      m_flags[index] = m_flags[newestIndex];
+      TransferFolder(newestIndex, index);
+
+      // Carry over the relevant flags from the root.
+      m_flags[index] |= nsMsgMessageFlags::Elided;
+      m_flags[index] |=
+          (flags & (MSG_VIEW_FLAG_ISTHREAD | MSG_VIEW_FLAG_HASCHILDREN));
+    }
+  }
+
   if (ReversedThreading()) {
