+                AppConstants.platform == "win" &&
+                file.leafName.endsWith(".lnk")
+              ) {
+                const uri = fileHandler.readShellLink(file);
+                file = uri.QueryInterface(Ci.nsIFileURL).file;
+                data = uri.spec;
+              } else {
