                 .getProtocolHandler("file")
-                .QueryInterface(Ci.nsIFileProtocolHandler)
-                .getURLSpecFromActualFile(data);
-              isValidAttachment = true;
+                .QueryInterface(Ci.nsIFileProtocolHandler);
+
