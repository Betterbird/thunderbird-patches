Bug 2047887 - Stop "all calendars disabled" notification appearing when a calendar is enabled. r=freaktechnik

Differential Revision: https://phabricator.services.mozilla.com/D306958

diff --git a/calendar/base/modules/calCalendarDeactivator.sys.mjs b/calendar/base/modules/calCalendarDeactivator.sys.mjs
--- a/calendar/base/modules/calCalendarDeactivator.sys.mjs
+++ b/calendar/base/modules/calCalendarDeactivator.sys.mjs
@@ -116,17 +116,17 @@ export var calendarDeactivator = {
     const value = "calendarDeactivated";
     for (const [notificationbox, l10nId] of notificationboxes) {
       const existingNotification = notificationbox.getNotificationWithValue(value);
 
       if (existingNotification) {
         if (isEnabled) {
           notificationbox.removeNotification(existingNotification);
         }
-      } else {
+      } else if (!isEnabled) {
         notificationbox
           .appendNotification(
             value,
             {
               label: { "l10n-id": l10nId },
               priority: notificationbox.PRIORITY_WARNING_MEDIUM,
             },
             null

