+ * Dispatch a cancelable close event and close the window.
+ */
+function requestWindowClose() {
+  const closeEvent = new CustomEvent("close", {
+    bubbles: true,
+    cancelable: true,
+  });
+
+  if (window.dispatchEvent(closeEvent)) {
+    window.close();
+  }
+}
