+   */
+  send(response, preventLFMunge = false) {
+    if (!preventLFMunge) {
+      response = response.replaceAll("\r\n", "\n").replaceAll("\n", "\r\n");
+    }
+
+    if (!response.endsWith("\n")) {
+      response += "\r\n";
