+  /**
+   * Return live protocol handlers, optionally restricted to a mailbox.
+   * Each handler represents one client connection.
+   *
+   * @param {ImapMailbox|string} [mailbox]
+   * @returns {IMAP_RFC3501_handler[]}
+   */
+  getConnections(mailbox) {
