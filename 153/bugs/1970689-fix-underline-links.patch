Bug 1970689 - Fix link underlining when pref layout.css.always_underline_links is set.

diff --git a/mail/base/content/aboutDialog.css b/mail/base/content/aboutDialog.css
--- a/mail/base/content/aboutDialog.css
+++ b/mail/base/content/aboutDialog.css
@@ -12,8 +12,13 @@
   @media (prefers-color-scheme: dark) {
     --link-decoration: underline;
   }
 
+  /* stylelint-disable-next-line media-query-no-invalid */
+  @media -moz-pref("layout.css.always_underline_links") {
+    --link-decoration: underline;
+  }
+
   @media (prefers-contrast) {
     --dialog-background: -moz-Dialog;
     --dialog-box-color: -moz-DialogText;
     --client-box-background: -moz-Dialog;
diff --git a/mail/themes/shared/mail/aboutExtra.css b/mail/themes/shared/mail/aboutExtra.css
--- a/mail/themes/shared/mail/aboutExtra.css
+++ b/mail/themes/shared/mail/aboutExtra.css
@@ -5,8 +5,22 @@
 @import url("chrome://messenger/skin/icons.css");
 @import url("chrome://messenger/skin/colors.css");
 @import url("chrome://messenger/skin/variables.css");
 
+:root {
+  :any-link, .text-link {
+    &:not(:hover) {
+      text-decoration: none;
+    }
+  }
+
+  @media -moz-pref("layout.css.always_underline_links") {
+    .text-link {
+      text-decoration: underline !important;
+    }
+  }
+}
+
 body {
   /* Override the absolute (px) font-size value in common-shared.css. */
   font-size: 1.1rem;
 }
