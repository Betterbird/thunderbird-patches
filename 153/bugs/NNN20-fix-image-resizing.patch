+/* ::::: image zoom system ::::: */
+/*
+ * Two attributes (shrinktofit, overflowing) create three visual states
+ * that the JS in msgHdrView.js, aboutMessage.js and contentAreaClick.js
+ * toggles between:
+ *
+ *  [shrinktofit]                    Image constrained to viewport width.
+ *  [shrinktofit][overflowing]       Same, plus zoom-in cursor. Click to expand.
+ *  [overflowing]:not([shrinktofit]) Image at full size, zoom-out cursor.
+ *                                   Click to shrink back.
+ *
+ * Non-linked images start in state 2 if overflowing, or state 1 otherwise.
+ * Linked images default to state 1 only (overflowing never set) unless
+ * pref mail.allow_zooming_image_links is true.
+ * Clicking an image with [overflowing] toggles its [shrinktofit] attribute,
+ * cycling between states 2 and 3. Window resize re-evaluates overflow.
+ */
 img {
   &[shrinktofit] {
     max-inline-size: 100% !important;
 
     &[overflowing] {
-      cursor: zoom-in;
+      cursor: zoom-in !important;
       /* If we detect we're shrinking the image, force it to keep its aspect
        * ratio, since it possibly had hard-coded sizings. */
       block-size: auto !important;
     }
   }
 
   &[overflowing]:not([shrinktofit]) {
-    cursor: zoom-out;
+    cursor: zoom-out !important;
     /* Unbound the sizing of the image so it is displayed at full size. */
     block-size: auto !important;
     inline-size: auto !important;
     max-inline-size: none !important;
