# HG changeset patch
# User Betterbird <betterbird@betterbird.eu>
# Date 1783936971 -7200
# Parent  dde1b08980ee68accdcf5b650046dc70533ada4e
Bug 2054385 - Fix body search where QP message ends with trailing =

diff --git a/mailnews/search/src/nsMsgSearchTerm.cpp b/mailnews/search/src/nsMsgSearchTerm.cpp
--- a/mailnews/search/src/nsMsgSearchTerm.cpp
+++ b/mailnews/search/src/nsMsgSearchTerm.cpp
@@ -831,8 +831,9 @@ nsresult nsMsgSearchTerm::MatchBody(nsIM
 
   nsCString compare;
   nsMsgBodyHandler bodyHandler(scope, msg);
   uint32_t seen = 0;
+  nsAutoCString charset;
   while (result == boolContinueLoop) {
     // Small hack so we don't look all through a message when someone has
     // specified "BODY IS foo".
     if (m_operator == nsMsgSearchOp::Is || m_operator == nsMsgSearchOp::Isnt) {
@@ -841,9 +842,8 @@ nsresult nsMsgSearchTerm::MatchBody(nsIM
       }
     }
 
     nsAutoCString buf;
-    nsAutoCString charset;
     bool needsQPReset = false;
     int32_t n = bodyHandler.GetNextLine(buf, charset, needsQPReset);
     if (n < 0) {
       break;  // EOF
@@ -876,8 +876,21 @@ nsresult nsMsgSearchTerm::MatchBody(nsIM
       compare.Truncate();
     }
   }
 
+  // A malformed message may end with a QP soft-line-break-like sequence
+  // (bare "=" at EOF), causing accumulated content to be deferred but
+  // never searched. Catch that here.
+  if (!compare.IsEmpty()) {
+    char startChar = (char)compare.CharAt(0);
+    if (startChar != '\r' && startChar != '\n') {
+      rv = MatchString(compare,
+                       charset.IsEmpty() ? msgCharset : charset.get(),
+                       &result);
+    }
+    compare.Truncate();
+  }
+
   *pResult = result;
   return rv;
 }
 
